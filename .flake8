[flake8]
# Practical ignores for a Databricks PySpark project
ignore =
    # PySpark overloads == so E711/E712 produce false positives in filter() calls
    E711,
    E712,
    # Databricks notebook-source files use module-level code (not imports) before imports
    E402,
    # Line continuation before/after binary operator — style preference
    W503,
    W504,
    # flake8-bugbear: not applicable to this project
    B006,
    B007,
    # B041: repeated key in dict literal — bugbear rule with false positives in generated code
    B041,
    # F821 undefined names — Databricks injects spark/dbutils at runtime
    F821,
    # Ambiguous variable name — too strict for data pipelines
    E741,
    # E999 syntax errors — Databricks notebooks use MAGIC comments that can trip E999
    # Only needed during static analysis; all notebook files are handled via per-file-ignores
    E999,
    # Bare except — acceptable in Databricks notebook context
    E722,
    B001,
    # E501 line too long — suppressed globally; enforce via per-file-ignores for new code
    E501

max-line-length = 120

exclude =
    .git,
    __pycache__,
    build,
    dist,
    .venv,
    venv,
    *.egg-info,
    data_platform/scratch/

per-file-ignores =
    # __init__ files: allow unused and star imports
    __init__.py: F401, F403
    # Databricks notebook sources: globals injected at runtime; module-level executable code is normal
    data_platform/src/notebook.py: F401, E302, E305, W292
    data_platform/src/dlt_pipeline.py: F401, E302, E305, W292
    # Silver layer Databricks notebooks: runtime globals + notebook-style code patterns
    data_platform/src/silver_layer_scripts/dcp_*.py: F401, F403, F405, F541, F811, F841, B001, E111, E117, E121, E122, E123, E124, E126, E127, E128, E131, E201, E202, E203, E222, E225, E231, E251, E261, E262, E265, E266, E271, E302, E303, E305, E402, E502, W291, W292, W293, W391
    data_platform/src/silver_layer_scripts/data_plat_cdc_logic*.py: F401, F403, E111, E121, E122, E123, E124, E126, E127, E128, E131, E201, E202, E203, E222, E225, E231, E251, E261, E262, E265, E266, E271, E302, E303, W291, W292, W293, W391, F541
    data_platform/src/silver_layer_scripts/qc_tools/*.py: F401, F403, F405, F541, F811, F841, B001, E111, E117, E121, E122, E123, E124, E125, E126, E127, E128, E131, E201, E202, E203, E222, E225, E226, E231, E251, E261, E265, E266, E302, E303, E305, E401, E502, W291, W292, W293, W391
    # Bronze layer Databricks notebooks: full notebook-style suppression
    data_platform/src/bronze_layer_scripts/*.py: F401, F403, F405, F541, F811, F841, B001, E111, E117, E121, E122, E123, E124, E125, E126, E127, E128, E131, E201, E202, E203, E222, E225, E226, E231, E251, E261, E265, E266, E302, E303, E305, E401, E502, W291, W292, W293, W391
    # Gold layer Databricks notebooks: full notebook-style suppression
    data_platform/src/gold_layer_scripts/**/*.py: F401, F403, F405, F541, F811, F841, B001, E111, E117, E121, E122, E123, E124, E125, E126, E127, E128, E131, E201, E202, E203, E222, E225, E226, E227, E231, E251, E261, E265, E266, E302, E303, E305, W291, W292, W293, W391
    # Databricks notebook utility scripts with special patterns
    utils/survey_metadata_management.py: E402, F401
    utils/qc_bridge_nps_table.py: F401, E302, E501, E402, W292